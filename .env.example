# Q50: .env.example para futuras chaves de API
# Copie para .env e preencha com seus valores reais

# Formspree endpoint (obtenha em formspree.io)
VITE_FORMSPREE_URL=https://formspree.io/f/YOUR_ID

# GitHub Token (opcional — aumenta rate limit de 60 para 5000 req/h)
VITE_GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# Plausible Analytics (Q51)
VITE_PLAUSIBLE_DOMAIN=kauancosta.dev
